---
import { site } from "../data/site.mjs";
import { withBase } from "../utils/urls.mjs";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__identity">
    <a class="footer-brand" href={withBase("/")}>Jamie Kazemier</a>
    <p>Rowing photography. Netherlands. Portfolio first.</p>
  </div>

  <nav class="site-footer__nav" aria-label="Footer navigation">
    <a href={withBase("/portfolio/")}>Portfolio</a>
    <a href={withBase("/contact/")}>Contact</a>
    <a href={site.shopHref} target="_blank" rel="noreferrer">{site.shopLabel}</a>
    <a href={`mailto:${site.email}`}>{site.email}</a>
    <a href={site.instagramUrl} target="_blank" rel="noreferrer">{site.instagramHandle}</a>
  </nav>

  <p class="site-footer__copyright">&copy; {year} Jamie Kazemier Photography.</p>
</footer>
