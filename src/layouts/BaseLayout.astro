---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const {
  title = "Jamie Kazemier Photography",
  description = "Rowing photography in the Netherlands by Jamie Kazemier.",
  heroHeader = false
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fbfaf6" />
    <title>{title}</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;700;800&family=Schibsted+Grotesk:wght@500;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class={heroHeader ? "has-hero-header" : ""}>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
