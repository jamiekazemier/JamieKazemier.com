---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site.mjs";
---

<BaseLayout title="Contact | Jamie Kazemier Photography" description="Minimal contact details for Jamie Kazemier Photography.">
  <section class="page-hero section">
    <p class="eyebrow">Contact</p>
    <h1>Instagram for quick contact. Email for the practical bits.</h1>
    <p>{site.contactLine}</p>
  </section>

  <section class="section contact-methods" aria-label="Contact methods">
    <a class="contact-method" href={site.instagramUrl} target="_blank" rel="noreferrer">
      <span class="eyebrow">Instagram</span>
      <strong>{site.instagramHandle}</strong>
      <p>Direct messages and recent work.</p>
    </a>
    <a class="contact-method" href={`mailto:${site.email}`}>
      <span class="eyebrow">Email</span>
      <strong>{site.email}</strong>
      <p>For image questions and anything practical.</p>
    </a>
    <a class="contact-method contact-method--shop" href={site.shopHref} target="_blank" rel="noreferrer">
      <span class="eyebrow">Shop</span>
      <strong>{site.shopLabel}</strong>
      <p>External gallery sales will live off-site.</p>
    </a>
  </section>
</BaseLayout>
