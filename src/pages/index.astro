---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { portfolioSequence, storyTeasers } from "../data/galleries.mjs";
import { site } from "../data/site.mjs";
import { withBase } from "../utils/urls.mjs";

const hero = {
  src: "/images/hero.jpg",
  alt: "Low-angle rowing shell racing across dark Dutch water with warm light."
};

const openingFrames = portfolioSequence.slice(0, 3);
---

<BaseLayout title="Jamie Kazemier Photography | Rowing Photography" description={site.description} heroHeader>
  <section class="home-hero" aria-label="Featured rowing photograph">
    <ResponsiveImage image={hero} class="home-hero__image" loading="eager" sizes="100vw" width="1800" height="1200" />
    <div class="home-hero__content">
      <p class="eyebrow">Rowing photography</p>
      <h1 class="home-hero__title">
        <span>Jamie</span>
        <span>Kazemier</span>
        <small>Photography</small>
      </h1>
      <p class="home-hero__statement">{site.heroStatement}</p>
      <div class="home-hero__actions">
        <a class="button button--solid" href={withBase("/portfolio/")}>Enter portfolio</a>
        <a class="button button--outline" href={site.shopHref} target="_blank" rel="noreferrer">{site.shopLabel}</a>
      </div>
    </div>
  </section>

  <section class="section manifesto" aria-labelledby="manifesto-title">
    <div class="section-heading">
      <p class="eyebrow">Portfolio first</p>
      <h2 id="manifesto-title">The site behaves like a wall of selected frames, not an event archive.</h2>
    </div>
    <p class="manifesto__text">{site.intro}</p>
  </section>

  <section class="section home-sequence" aria-labelledby="home-sequence-title">
    <div class="section-heading">
      <p class="eyebrow">Opening frames</p>
      <h2 id="home-sequence-title">Pressure. Rhythm. Water that looks almost metallic.</h2>
    </div>

    <div class="home-sequence__grid">
      {openingFrames.map((entry) => (
        <figure class:list={["home-frame", `home-frame--${entry.layout}`]}>
          <ResponsiveImage
            image={entry.image}
            class="home-frame__image"
            sizes="(min-width: 960px) 33vw, 100vw"
            loading="eager"
          />
        </figure>
      ))}
    </div>

    <a class="inline-link" href={withBase("/portfolio/")}>View the full sequence</a>
  </section>

  <section class="section story-teasers" aria-labelledby="story-teasers-title">
    <div class="section-heading">
      <p class="eyebrow">Selected stories</p>
      <h2 id="story-teasers-title">A few regattas earn more than a single frame.</h2>
    </div>

    <div class="story-teasers__grid">
      {storyTeasers.map((story) => (
        <a class="story-card" href={withBase(story.href)}>
          <ResponsiveImage image={story.cover} class="story-card__image" sizes="(min-width: 960px) 44vw, 100vw" />
          <div class="story-card__body">
            <span>{story.location} / {story.date}</span>
            <strong>{story.title}</strong>
            <p>{story.summary}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section contact-strip" aria-labelledby="contact-strip-title">
    <div class="section-heading">
      <p class="eyebrow">Contact</p>
      <h2 id="contact-strip-title">Light contact only. The work stays in front.</h2>
    </div>
    <p class="contact-strip__text">{site.contactLine}</p>
    <div class="contact-strip__actions">
      <a class="inline-link" href={`mailto:${site.email}`}>{site.email}</a>
      <a class="inline-link" href={site.instagramUrl} target="_blank" rel="noreferrer">{site.instagramHandle}</a>
      <a class="inline-link" href={site.shopHref} target="_blank" rel="noreferrer">{site.shopLabel}</a>
    </div>
  </section>
</BaseLayout>
