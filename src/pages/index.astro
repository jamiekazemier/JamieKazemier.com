---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { portfolioSequence, storyTeasers } from "../data/galleries.mjs";
import { site } from "../data/site.mjs";
import { withBase } from "../utils/urls.mjs";

const hero = {
  src: "/images/hero.jpg",
  alt: "Low-angle rowing shell racing across dark Dutch water with warm light."
};

const openingFrames = portfolioSequence.slice(0, 6);
const [leadStory, ...secondaryStories] = storyTeasers;
---

<BaseLayout title="Jamie Kazemier Photography | Rowing Photography" description={site.description} heroHeader>
  <section class="home-hero" aria-label="Featured rowing photograph">
    <ResponsiveImage image={hero} class="home-hero__image" loading="eager" sizes="100vw" width="1800" height="1200" />
    <div class="home-hero__content">
      <p class="eyebrow">Rowing photography</p>
      <h1 class="home-hero__title">
        <span>Jamie</span>
        <span>Kazemier</span>
        <small>Photography</small>
      </h1>
      <p class="home-hero__statement">{site.heroStatement}</p>
      <div class="home-hero__actions">
        <a class="button button--solid" href={withBase("/portfolio/")}>Enter portfolio</a>
        <a class="button button--outline" href={withBase(site.shopHref)}>{site.shopLabel}</a>
      </div>
    </div>
  </section>

  <section class="section section--tight home-sequence" aria-labelledby="home-sequence-title">
    <div class="home-sequence__intro">
      <div class="section-heading">
        <p class="eyebrow">Portfolio first</p>
        <h2 id="home-sequence-title">The work stays edited, selected, and close to the race.</h2>
      </div>
      <p class="manifesto__text">{site.intro}</p>
    </div>

    <div class="home-bento" aria-label="Opening rowing image masonry">
      {openingFrames.map((entry, index) => (
        <figure class:list={["home-bento__item", `home-bento__item--${entry.layout}`]}>
          <ResponsiveImage
            image={entry.image}
            class="home-bento__image"
            sizes="(min-width: 960px) 33vw, (min-width: 720px) 50vw, 100vw"
            loading={index < 2 ? "eager" : "lazy"}
          />
        </figure>
      ))}
    </div>

    <a class="inline-link" href={withBase("/portfolio/")}>View the full sequence</a>
  </section>

  <section class="section section--tight story-teasers" aria-labelledby="story-teasers-title">
    <div class="section-heading">
      <p class="eyebrow">Selected stories</p>
      <h2 id="story-teasers-title">A few regattas hold long enough to earn a fuller sequence.</h2>
    </div>

    <div class="story-teasers__layout">
      <a class="story-card story-card--lead" href={withBase(leadStory.href)}>
        <ResponsiveImage image={leadStory.cover} class="story-card__image" sizes="(min-width: 960px) 52vw, 100vw" />
        <div class="story-card__body">
          <span>{leadStory.location} / {leadStory.date}</span>
          <strong>{leadStory.title}</strong>
          <p>{leadStory.summary}</p>
        </div>
      </a>

      <div class="story-teasers__stack">
        {secondaryStories.map((story) => (
          <a class="story-card story-card--compact" href={withBase(story.href)}>
            <ResponsiveImage image={story.cover} class="story-card__image" sizes="(min-width: 960px) 25vw, 100vw" />
            <div class="story-card__body">
              <span>{story.location} / {story.date}</span>
              <strong>{story.title}</strong>
              <p>{story.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--tight contact-strip" aria-labelledby="contact-strip-title">
    <div class="section-heading">
      <p class="eyebrow">Contact</p>
      <h2 id="contact-strip-title">Direct contact, quick guidance, and a clear route to race images.</h2>
    </div>
    <p class="contact-strip__text">{site.contactLine}</p>
    <div class="contact-strip__actions">
      <a class="inline-link" href={`mailto:${site.email}`}>{site.email}</a>
      <a class="inline-link" href={site.instagramUrl} target="_blank" rel="noreferrer">{site.instagramHandle}</a>
      <a class="inline-link" href={withBase(site.shopHref)}>{site.shopLabel}</a>
    </div>
  </section>
</BaseLayout>
