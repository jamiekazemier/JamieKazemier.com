---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { portfolioSequence } from "../data/galleries.mjs";
import { withBase } from "../utils/urls.mjs";
---

<BaseLayout title="Portfolio | Jamie Kazemier Photography" description="Curated rowing photography by Jamie Kazemier.">
  <section class="page-hero section">
    <p class="eyebrow">Portfolio</p>
    <h1>Ten selected frames, with only a few exits into deeper stories.</h1>
    <p>No captions unless a page earns them. No archive grid. Just the strongest rowing photographs in sequence.</p>
  </section>

  <section class="section portfolio-sequence" aria-label="Curated portfolio sequence">
    {portfolioSequence.map((entry) =>
      entry.href ? (
        <a class:list={["sequence-item", `sequence-item--${entry.layout}`, "is-linked"]} href={withBase(entry.href)}>
          <ResponsiveImage
            image={entry.image}
            class="sequence-item__image"
            sizes="(min-width: 960px) 80vw, 100vw"
            loading="eager"
          />
          <span class="sequence-item__label">Story / {entry.label}</span>
        </a>
      ) : (
        <figure class:list={["sequence-item", `sequence-item--${entry.layout}`]}>
          <ResponsiveImage
            image={entry.image}
            class="sequence-item__image"
            sizes="(min-width: 960px) 80vw, 100vw"
            loading="eager"
          />
        </figure>
      )
    )}
  </section>
</BaseLayout>
